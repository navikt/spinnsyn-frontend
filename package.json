{
    "name": "spinnsyn-frontend",
    "version": "0.1.1",
    "private": true,
    "engines": {
        "node": "24"
    },
    "dependencies": {
        "@date-fns/tz": "^1.5.0",
        "@grafana/faro-web-sdk": "^2.8.2",
        "@navikt/aksel-icons": "^7.40.0",
        "@navikt/ds-css": "^7.40.0",
        "@navikt/ds-react": "^7.40.0",
        "@navikt/ds-tailwind": "^7.40.0",
        "@navikt/ds-tokens": "^7.40.0",
        "@navikt/nav-dekoratoren-moduler": "^3.6.3",
        "@navikt/next-api-proxy": "^4.1.5",
        "@navikt/next-logger": "^1.35.0",
        "@navikt/oasis": "^3.8.0",
        "@tanstack/react-query": "^5.101.2",
        "@unleash/nextjs": "^1.6.7",
        "classnames": "^2.5.1",
        "cookie": "^1.0.2",
        "date-fns": "^4.4.0",
        "html-react-parser": "^6.1.4",
        "jose": "^6.2.3",
        "next-logger": "^5.0.2",
        "node-cache": "^5.1.2",
        "pino-pretty": "^13.1.3",
        "prom-client": "^15.1.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "remeda": "^2.39.0",
        "tailwind-merge": "^3.6.0",
        "typescript": "^5.9.3",
        "uuid": "^14.0.1"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.12.1",
        "@navikt/eslint-config-teamsykmelding": "^7.1.0",
        "@playwright/test": "^1.61.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/classnames": "^2.3.4",
        "@types/cookie": "^0.6.0",
        "@types/node": "^22.10.5",
        "@types/react": "^19.2.17",
        "@types/uuid": "^11.0.0",
        "@vitejs/plugin-react": "^6.0.3",
        "autoprefixer": "^10.5.2",
        "axe-core": "^4.12.1",
        "eslint": "^8.57.0",
        "eslint-config-next": "^15.5.4",
        "next": "^15.5.18",
        "postcss": "^8.5.15",
        "prettier": "^3.8.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "start-server-and-test": "^3.0.11",
        "tailwindcss": "^3.4.17",
        "ts-loader": "^9.5.7",
        "vitest": "^4.1.10"
    },
    "scripts": {
        "dev": "MOCK_BACKEND=true next dev -p 3000 | pino-pretty",
        "dev-ingen-dekorator": "MOCK_BACKEND=true NO_DECORATOR=true npm run dev | pino-pretty",
        "interne": "SPINNSYN_FRONTEND_INTERNE=true NO_DECORATOR=true npm run dev | pino-pretty",
        "start": "next start -p 3000",
        "start-ingen-dekorator": "NO_DECORATOR=true npm start",
        "arkiv": "npm run build && npm run start-ingen-dekorator",
        "build": "next build",
        "test": "vitest",
        "test:ci": "vitest --run",
        "play": "PLAYWRIGHT_ALL=true npx playwright test --ui",
        "play-headless": "PLAYWRIGHT_HTML_OPEN=never npx playwright test",
        "play-build": "export PLAYWRIGHT_ALL=true BUILD=true; npm run build && npx playwright test --ui",
        "play-headless-build": "PLAYWRIGHT_HTML_OPEN=never export BUILD=true; npm run build && npx playwright test",
        "prettier:write": "prettier --write .",
        "prettier:check": "prettier --check .",
        "lint": "eslint --ext=ts,tsx src playwright",
        "lint:fix": "eslint --ext=ts,tsx src playwright --fix",
        "format": "npm run prettier:write && npm run lint:fix"
    },
    "eslintConfig": {
        "extends": [
            "@navikt/eslint-config-teamsykmelding",
            "next/core-web-vitals"
        ],
        "rules": {
            "@typescript-eslint/explicit-function-return-type": "off",
            "@typescript-eslint/no-explicit-any": "off",
            "@typescript-eslint/no-non-null-assertion": "off"
        },
        "overrides": [
            {
                "files": [
                    "**/playwright/**/*.{js,ts}"
                ],
                "rules": {
                    "testing-library/prefer-screen-queries": "off"
                }
            }
        ]
    },
    "prettier": "@navikt/eslint-config-teamsykmelding/prettier"
}
